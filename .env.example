# Environment Variables for Fitverse Deployment

# Backend API URL
# For production, set this to your deployed backend URL (e.g., https://fitverse-backend.herokuapp.com)
VITE_BACKEND_URL=http://localhost:3001

# AI Engine URL  
# For production, set this to your deployed AI engine URL (e.g., https://fitverse-ai.herokuapp.com)
VITE_AI_ENGINE_URL=http://localhost:8000
