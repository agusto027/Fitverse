{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install frontend dependencies",
			"type": "shell",
			"command": "npm",
			"args": [
				"install"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run Vite dev server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Install backend dependencies",
			"type": "shell",
			"command": "npm",
			"args": [
				"install",
				"--prefix",
				"backend"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run backend server",
			"type": "shell",
			"command": "node",
			"args": [
				"backend/server.js"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		}
	]
}